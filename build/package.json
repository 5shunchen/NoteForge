{
  "name": "NoteForge",
  "version": "4.1.0",
  "description": "NoteForge - Markdown 笔记工具",
  "main": "main.js",
  "author": "NoteForge Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.noteforge.app",
    "productName": "NoteForge",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "build",
      "app": "src"
    },
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "src/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NoteForge",
      "installerIcon": "src/icon.ico",
      "uninstallerIcon": "src/icon.ico",
      "installerHeaderIcon": "src/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerLanguages": ["zh_CN"],
      "language": "2052",
      "license": "LICENSE",
      "include": "build/installer.nsh"
    }
  }
}
